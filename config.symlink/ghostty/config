window-decoration = none
copy-on-select = clipboard

# Each ghostty window starts its own (auto-numbered) tmux session, so
# windows are independent — closing a ghostty window ends that session's
# tabs. To attach to an existing session instead, run `tmux attach` or
# `tmux a -t <name>` from a fresh ghostty window.
command = /opt/homebrew/bin/tmux

# cmd+shift+, is remapped to swap tabs left, so reload moves to cmd+opt+,
keybind = cmd+opt+comma=reload_config

# Cmd shortcuts route through tmux's prefix (C-Space, see tmux.ghostty.conf).
# C-Space is byte \x00 — chosen so C-b and C-s pass through untouched
# to nested tmux sessions on remote hosts.
keybind = cmd+t=text:\x00c
keybind = cmd+w=text:\x00&
keybind = cmd+shift+left_bracket=text:\x00p
keybind = cmd+shift+right_bracket=text:\x00n
keybind = cmd+shift+comma=text:\x00<
keybind = cmd+shift+period=text:\x00>

keybind = cmd+digit_1=text:\x001
keybind = cmd+digit_2=text:\x002
keybind = cmd+digit_3=text:\x003
keybind = cmd+digit_4=text:\x004
keybind = cmd+digit_5=text:\x005
keybind = cmd+digit_6=text:\x006
keybind = cmd+digit_7=text:\x007
keybind = cmd+digit_8=text:\x008
keybind = cmd+digit_9=text:\x009
